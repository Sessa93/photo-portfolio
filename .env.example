# Secrets for `docker compose` on the deploy target (e.g. the droplet).
# Copy to `.env` next to docker-compose.yml and fill in real values — `.env` is
# gitignored and is never touched by the deploy workflow's `git reset --hard`.
#
# This is distinct from .env.local.example, which is for local `next dev`.

# Admin credentials for the one-shot `setup` service, run manually (not part
# of deploy):  docker compose run --rm setup
# You can also pass them inline instead of setting them here, e.g.
#   docker compose run --rm -e ADMIN_USERNAME=admin -e ADMIN_PASSWORD=... setup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-min-8-chars

# Optional image tag overrides (default to the tags the deploy workflow pushes).
# IMAGE_TAG=latest   # webapp image
# BASE_TAG=base      # shared base image used by the setup service

SESSION_SECRET=generate-with-openssl-rand-base64-32
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
INSTAGRAM_URL=https://www.instagram.com/your_instagram_handle
CONTACT_EMAIL=your-contact-email@example.com
